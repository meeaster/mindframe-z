{
  "lsp": true,
  "reference": {
    "opencode": "https://github.com/anomalyco/opencode"
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5.4-mini",
      "reasoningEffort": "medium"
    }
  },
  "permission": {
    "websearch": "allow",
    "external_directory": {
      "/home/mark/work/**": "allow",
      "/home/mark/references/**": "allow",
      "~/.local/share/mise/**": "allow",
      "/mnt/c/vaults/wiki/**": "allow"
    },
    "edit": {
      "/home/mark/references/**": "deny"
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "/home/mark/code/mindframe-z/configs/work/AGENTS.md",
    "/home/mark/code/mindframe-z/configs/work/references.md"
  ],
  "plugin": [
    "file:///home/mark/code/mindframe-z/configs/work/opencode/plugins/mindframe-z-example.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "qmd": {
      "type": "local",
      "command": [
        "qmd",
        "mcp"
      ],
      "enabled": false
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "openai-docs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
      "enabled": false
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws",
      "enabled": false
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "confluence": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
      "enabled": false
    }
  }
}
