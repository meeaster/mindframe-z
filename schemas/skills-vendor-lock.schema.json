{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "skills": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "required": [
          "commit",
          "digest"
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
