{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "profile": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "references_dir": {
      "default": "~/references",
      "type": "string"
    },
    "extra_folders": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "default": "",
            "type": "string"
          },
          "read": {
            "default": "allow",
            "type": "string",
            "enum": [
              "allow",
              "ask",
              "deny"
            ]
          },
          "edit": {
            "default": "allow",
            "type": "string",
            "enum": [
              "allow",
              "ask",
              "deny"
            ]
          }
        },
        "required": [
          "path"
        ]
      }
    },
    "opencode": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  }
}
