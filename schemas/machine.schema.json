{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "profile": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "references_dir": {
      "default": "~/references",
      "type": "string"
    },
    "extra_folders": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "default": "",
            "type": "string"
          },
          "read": {
            "default": "allow",
            "type": "string",
            "enum": [
              "allow",
              "ask",
              "deny"
            ]
          },
          "edit": {
            "default": "allow",
            "type": "string",
            "enum": [
              "allow",
              "ask",
              "deny"
            ]
          }
        },
        "required": [
          "path"
        ]
      }
    },
    "git": {
      "default": {},
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      }
    },
    "sandbox": {
      "default": {},
      "type": "object",
      "properties": {
        "credentials": {
          "type": "string",
          "enum": [
            "bedrock",
            "subscription"
          ]
        }
      }
    },
    "thread": {
      "default": {
        "destinations": []
      },
      "type": "object",
      "properties": {
        "destinations": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[a-z0-9][a-z0-9._-]*$"
              },
              "remote": {
                "type": "string"
              },
              "no_push": {
                "default": false,
                "type": "boolean"
              },
              "default": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    },
    "opencode": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  }
}
