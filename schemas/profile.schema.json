                "required": [
                  "name",
                  "providers"
                ]
              }
            },
            "agents": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "model": {
                    "type": "string",
                    "minLength": 1
                  },
                  "variant": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "model"
                ]
              }
            }
          }
        }
      }
    },
    "claude": {
      "default": {
