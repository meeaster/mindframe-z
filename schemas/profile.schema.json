{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "extends": {
      "type": "string"
    },
    "description": {
      "default": "",
      "type": "string"
    },
    "agents": {
      "default": [
        "opencode",
        "claude-code"
      ],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "opencode",
          "claude-code"
        ]
      }
    },
    "instructions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "opencode",
                "claude-code",
                "all"
              ]
            }
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "mcp": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "targets": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "opencode",
                "claude-code"
              ]
            }
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "enabled"
        ]
      }
    },
    "opencode": {
      "default": {
        "config": {},
        "plugins": [],
        "commands": []
      },
      "type": "object",
      "properties": {
        "config": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        },
        "plugins": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "claude": {
      "default": {
        "settings": {}
      },
      "type": "object",
      "properties": {
        "model": {
          "type": "string"
        },
        "settings": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      }
    },
    "mise": {
      "default": {
        "tools": {},
        "env": {},
        "tool_alias": {},
        "settings": {}
      },
      "type": "object",
      "properties": {
        "tools": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            ]
          }
        },
        "env": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "tool_alias": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "settings": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      }
    },
    "dotfiles": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": false
}
