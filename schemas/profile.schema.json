          },
          "additionalProperties": {}
        },
        "plugins": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agents": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agent_task": {
          "type": "object",
          "properties": {
            "models": {
              "default": [],
