    "thread": {
      "default": {
        "destinations": [],
        "defaults": {},
        "credentials": "subscription"
      },
      "type": "object",
      "properties": {
        "destinations": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[a-z0-9][a-z0-9._-]*$"
              },
              "remote": {
                "type": "string"
              },
              "no_push": {
                "default": false,
                "type": "boolean"
