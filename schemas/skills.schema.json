{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "skills": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "local",
              "git"
            ]
          },
          "repo": {
            "type": "string"
          },
          "skill": {
            "type": "string"
          },
          "description": {
            "default": "",
            "type": "string"
          },
          "installer": {
            "default": "skills",
            "type": "string",
            "const": "skills"
          }
        },
        "required": [
          "name",
          "source"
        ]
      }
    }
  }
}
