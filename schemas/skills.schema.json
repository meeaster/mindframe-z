{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "skills": {
      "default": [],
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "description": {
                "default": "",
                "type": "string"
              },
              "source": {
                "type": "string",
                "const": "local"
              },
              "skill": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.\\.?($|\\/))(?!.*\\/\\/)(?!.*(?:^|\\/)\\.git(?:\\/|$)).+$"
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "description": {
                "default": "",
                "type": "string"
              },
              "source": {
                "type": "string",
                "const": "vendored"
              },
              "repo": {
                "type": "string",
                "pattern": "^https:\\/\\/(?![^/]*@)\\S+$"
              },
              "ref": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!-)(?!.*\\s).+$"
              },
              "subtree": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.\\.?($|\\/))(?!.*\\/\\/)(?!.*(?:^|\\/)\\.git(?:\\/|$)).+$"
              }
            },
            "required": [
              "name",
              "source",
              "repo",
              "ref",
              "subtree"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
