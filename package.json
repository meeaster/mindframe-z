{
  "name": "mindframe-z",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mfz": "./bin/mfz"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run fmt:check && npm run build && npm test",
    "dev": "tsx src/cli/mfz.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "schemas": "tsx src/core/generate-schemas.ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@clack/core": "1.3.1",
    "@clack/prompts": "1.4.0",
    "@commander-js/extra-typings": "14.0.0",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "jsonc-parser": "3.3.1",
    "smol-toml": "1.6.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.15.4",
    "@types/node": "25.7.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
