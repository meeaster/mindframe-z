{
  "name": "mindframe-z",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mfz": "./bin/mfz"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm fmt:check && pnpm build && pnpm check:bun && pnpm test",
    "check:bun": "bun build --target=bun src/cli/mfz-bun.ts --outdir dist/.bun-check",
    "dev": "tsx src/cli/mfz.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "release": "node scripts/build-release.mjs",
    "schemas": "tsx scripts/generate-schemas.ts",
    "test": "vitest run src",
    "test:all": "vitest run",
    "test:apply": "vitest run tests/integration/apply.test.ts",
    "test:doctor": "vitest run tests/integration/doctor.test.ts",
    "test:dotfiles": "vitest run tests/integration/dotfiles.test.ts",
    "test:integration": "vitest run tests/integration",
    "test:mise": "vitest run tests/integration/mise.test.ts",
    "test:plugins": "vitest run --passWithNoTests opencode",
    "test:refs": "vitest run tests/integration/refs.test.ts",
    "test:sandbox": "vitest run src/sandbox tests/integration/sandbox.test.ts",
    "test:sessions": "vitest run src/sessions",
    "test:skills": "vitest run src/skills src/tui tests/integration/skills.test.ts tests/integration/skills-profile.test.ts",
    "test:thread": "vitest run src/thread"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1079.0",
    "@clack/core": "1.4.3",
    "@clack/prompts": "1.7.0",
    "@commander-js/extra-typings": "15.0.0",
    "@msgpack/msgpack": "3.1.3",
    "commander": "15.0.0",
    "execa": "9.6.1",
    "jsonc-parser": "3.3.1",
    "smol-toml": "1.7.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.13",
    "@types/node": "26.1.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
