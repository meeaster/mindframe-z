AWS_PROFILE=bedrock-sandbox
BEDROCK_AWS_REGION=us-west-2
BEDROCK_SIGV4_PROXY_PORT=8080
AGENT_VAULT_API_PORT=14321
AGENT_VAULT_MITM_PORT=14322
# Copy this file to .env and set this locally. Do not commit .env.
AGENT_VAULT_MASTER_PASSWORD=
# Agent token with instance role no-access and vault grant local-ai-dev-sandbox:proxy.
AGENT_VAULT_TOKEN=

# Set to 0 to launch the agent without the credentialed remote MCP shims.
SANDBOX_MCP_BROKER_ENABLED=1
